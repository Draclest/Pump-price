# =============================================================================
# Prix à la Pompe — configuration d'environnement
#
# INSTRUCTIONS :
#   1. Copier ce fichier : cp .env.example .env
#   2. Remplir toutes les valeurs marquées REQUIRED
#   3. Ne jamais committer .env en version control (déjà dans .gitignore)
#
# Variables marquées REQUIRED : l'application refusera de démarrer sans elles.
# =============================================================================


# =============================================================================
# PORTS EXPOSÉS SUR L'HÔTE
# Valeur = numéro de port uniquement (ex: 8000, pas http://...)
# =============================================================================

FRONTEND_PORT=4200
BACKEND_PORT=8000

# ⚠️  Ne pas exposer Elasticsearch en production.
# Décommenter uniquement pour le debug local.
# ELASTICSEARCH_PORT=9200


# =============================================================================
# BACKEND_URL — URL interne Docker vers le backend (vue par Nginx)
# Pour Docker Compose standard : ne pas modifier.
# =============================================================================

BACKEND_URL=http://backend:8000


# =============================================================================
# ELASTICSEARCH
# ELASTICSEARCH_URL : URL interne Docker (port conteneur, toujours 9200)
# ELASTICSEARCH_PASSWORD : REQUIRED — choisir un mot de passe fort
# ELASTICSEARCH_VERIFY_CERTS : mettre true en production avec des vrais certs TLS
# =============================================================================

ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=           # REQUIRED — choisir un mot de passe fort et unique
ELASTICSEARCH_VERIFY_CERTS=false  # Mettre true en production avec TLS activé


# =============================================================================
# SÉCURITÉ
# =============================================================================

# Origines autorisées pour les requêtes CORS (séparées par des virgules).
# En développement local : http://localhost:4200
# En production : https://votre-domaine.com
CORS_ALLOWED_ORIGINS=http://localhost:4200

# Nombre maximum de requêtes par minute par IP (protection DoS).
RATE_LIMIT_PER_MINUTE=60

# Clé API pour les endpoints d'ingestion (/api/v1/ingestion/trigger).
# REQUIRED pour utiliser ces endpoints — laisser vide pour les désactiver.
# Générer avec : openssl rand -hex 32
INGESTION_API_KEY=    # REQUIRED si vous voulez déclencher l'ingestion manuellement


# =============================================================================
# APPLICATION
# =============================================================================

LOG_LEVEL=INFO
# Valeurs possibles : DEBUG | INFO | WARNING | ERROR


# =============================================================================
# OPENTELEMETRY (observabilité — optionnel)
# =============================================================================

OTEL_EXPORTER_TYPE=console
# Valeurs possibles :
#   console → affiche les traces dans les logs Docker (défaut, pas d'export externe)
#   otlp    → envoie vers un collecteur OpenTelemetry (Jaeger, Tempo, Grafana, etc.)
#   jaeger  → envoie directement vers Jaeger

OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# Utilisé uniquement si OTEL_EXPORTER_TYPE=otlp ou jaeger

OTEL_SERVICE_NAME=prix-pompe-api


# =============================================================================
# INGESTION DES DONNÉES
# =============================================================================

INGESTION_SCHEDULE=0 11 * * *
# Format cron : minute heure jour mois jour_semaine
# Exemples :
#   0 11 * * *   → tous les jours à 11h (recommandé, dataset mis à jour à 11h)
#   0 */6 * * *  → toutes les 6 heures

OSM_REFRESH_DAYS=7
# Nombre de jours avant de re-fetcher les données OpenStreetMap

PRICE_HISTORY_DAYS=30
# Nombre de jours d'historique de prix à conserver
