# Elasticsearch
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme

# Backend
BACKEND_PORT=8000
LOG_LEVEL=INFO

# OpenTelemetry
OTEL_EXPORTER_TYPE=console  # console | otlp | jaeger
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME=prix-pompe-api

# Data ingestion
DATA_GOUV_URL=https://data.economie.gouv.fr/api/explore/v2.1/catalog/datasets/prix-des-carburants-en-france-flux-instantane-v2/exports/json
INGESTION_SCHEDULE=0 */6 * * *  # Every 6 hours
