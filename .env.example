# =============================================================================
# PORTS EXPOSÉS SUR L'HÔTE
# Valeur = numéro de port uniquement (ex: 8000, pas http://...)
# Ces ports sont ceux accessibles depuis l'extérieur du serveur.
# =============================================================================

FRONTEND_PORT=4200
# → interface web accessible sur http://<serveur>:4200

BACKEND_PORT=8000
# → API REST accessible sur http://<serveur>:8000

ELASTICSEARCH_PORT=9200
# → Elasticsearch accessible sur http://<serveur>:9200
# ⚠️  En production : commenter cette ligne pour ne PAS exposer ES à l'extérieur


# =============================================================================
# BACKEND_URL — URL complète du backend telle que vue par le conteneur Nginx
# Valeur = URL complète avec http:// et le port INTERNE du conteneur (toujours 8000)
#
# ⚠️  Ce port (8000) est le port INTERNE Docker, pas BACKEND_PORT ci-dessus.
#     Changer BACKEND_PORT ne change PAS ce 8000 ici.
#
# Cas standard Docker Compose  → http://backend:8000   (ne pas changer)
# Backend sur un autre serveur → http://192.168.1.10:8000
# Backend derrière un domaine  → http://api.mondomaine.fr
# =============================================================================

BACKEND_URL=http://backend:8000


# =============================================================================
# ELASTICSEARCH — connexion depuis le backend
# Valeur = URL complète avec http:// et le port INTERNE du conteneur (toujours 9200)
#
# ⚠️  Ce 9200 est le port INTERNE Docker, pas ELASTICSEARCH_PORT ci-dessus.
#
# Cas standard Docker Compose → http://elasticsearch:9200  (ne pas changer)
# ES sur un autre serveur     → http://192.168.1.20:9200
# =============================================================================

ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=changeme
# ⚠️  Changer ce mot de passe avant tout déploiement en production


# =============================================================================
# APPLICATION
# =============================================================================

LOG_LEVEL=INFO
# Valeurs possibles : DEBUG | INFO | WARNING | ERROR


# =============================================================================
# OPENTELEMETRY (observabilité — optionnel)
# =============================================================================

OTEL_EXPORTER_TYPE=console
# Valeurs possibles :
#   console → affiche les traces dans les logs Docker (pas d'export externe)
#   otlp    → envoie vers un collecteur OpenTelemetry (Jaeger, Tempo, etc.)
#   jaeger  → envoie directement vers Jaeger

OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# Utilisé uniquement si OTEL_EXPORTER_TYPE=otlp ou jaeger
# Valeur = URL complète avec http:// et le port du collecteur

OTEL_SERVICE_NAME=prix-pompe-api
# Valeur = chaîne libre, apparaît dans les traces


# =============================================================================
# INGESTION DES DONNÉES
# =============================================================================

DATA_GOUV_URL=https://data.economie.gouv.fr/api/explore/v2.1/catalog/datasets/prix-des-carburants-en-france-flux-instantane-v2/exports/json
# Ne pas modifier sauf si la source change

INGESTION_SCHEDULE=0 */6 * * *
# Format cron : minute heure jour mois jour_semaine
# Exemples :
#   0 */6 * * *  → toutes les 6 heures (défaut)
#   0 */2 * * *  → toutes les 2 heures
#   0 11 * * *   → tous les jours à 11h
